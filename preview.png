<!DOCTYPE html>
<html>
<head>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: #0A0F1E; font-family: 'Noto Sans JP', 'DM Sans', sans-serif; }

  .shell { display: flex; flex-direction: column; height: 620px; border-radius: 12px; overflow: hidden; border: 1px solid #1E2D45; }

  /* header */
  .hdr { background: #111827; border-bottom: 1px solid #1E2D45; padding: 10px 18px; display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
  .hdr-icon { width: 28px; height: 28px; border-radius: 6px; background: linear-gradient(135deg, #0277BD, #F0B429); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 13px; flex-shrink: 0; }
  .hdr-title { color: #E2EAF4; font-size: 12px; font-weight: 800; letter-spacing: 0.02em; }
  .hdr-sub { color: #6B7E99; font-size: 9px; letter-spacing: 0.06em; }
  .hdr-badges { margin-left: auto; display: flex; gap: 6px; }
  .badge { padding: 3px 8px; border-radius: 5px; font-size: 9px; font-weight: 700; letter-spacing: 0.06em; }
  .badge-green { background: #34D39922; border: 1px solid #34D39966; color: #34D399; }
  .badge-purple { background: #A78BFA22; border: 1px solid #A78BFA66; color: #A78BFA; }
  .badge-orange { background: #FB923C22; border: 1px solid #FB923C66; color: #FB923C; }
  .badge-blue { background: #0D2137; border: 1px solid #1A3A5C; color: #4FC3F7; }

  /* body */
  .body { display: flex; flex: 1; overflow: hidden; }

  /* sidebar */
  .sidebar { width: 200px; background: #111827; border-right: 1px solid #1E2D45; padding: 14px 14px; flex-shrink: 0; overflow: hidden; }
  .sidebar-section { color: #6B7E99; font-size: 8px; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 10px; padding-bottom: 6px; border-bottom: 1px solid #1E2D45; }
  .section-label { color: #4FC3F7; font-size: 8px; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px; margin-top: 10px; }
  .slider-row { margin-bottom: 10px; }
  .slider-label { display: flex; justify-content: space-between; margin-bottom: 4px; }
  .slider-name { color: #6B7E99; font-size: 8px; }
  .slider-val { color: #F0B429; font-size: 8px; font-weight: 700; font-family: monospace; }
  .slider-track { height: 4px; background: #1E2D45; border-radius: 2px; position: relative; }
  .slider-fill { height: 100%; border-radius: 2px; background: linear-gradient(90deg, #0277BD, #F0B429); }
  .slider-thumb { width: 8px; height: 8px; border-radius: 50%; background: #F0B429; position: absolute; top: -2px; transform: translateX(-50%); }

  .toggle { margin-bottom: 8px; padding: 8px 9px; border-radius: 7px; cursor: pointer; }
  .toggle-green { background: #34D39918; border: 1px solid #34D39944; }
  .toggle-purple { background: #A78BFA18; border: 1px solid #A78BFA44; }
  .toggle-orange { background: #FB923C18; border: 1px solid #FB923C44; }
  .toggle-row { display: flex; align-items: center; gap: 7px; }
  .pill { width: 24px; height: 12px; border-radius: 6px; position: relative; flex-shrink: 0; }
  .pill-green { background: #34D399; }
  .pill-purple { background: #A78BFA; }
  .pill-orange { background: #FB923C; }
  .pill-dot { width: 8px; height: 8px; border-radius: 50%; background: #fff; position: absolute; top: 2px; right: 2px; }
  .toggle-label { font-size: 8px; font-weight: 700; }
  .toggle-sub { font-size: 7px; color: #6B7E99; margin-top: 2px; }
  .tg-green { color: #34D399; }
  .tg-purple { color: #A78BFA; }
  .tg-orange { color: #FB923C; }

  /* main */
  .main { flex: 1; padding: 14px; overflow: hidden; display: flex; flex-direction: column; gap: 10px; }

  /* kpi row */
  .kpi-row { display: flex; gap: 8px; flex-shrink: 0; }
  .kpi { background: #111827; border: 1px solid #1E2D45; border-radius: 8px; padding: 10px 12px; flex: 1; }
  .kpi-label { color: #6B7E99; font-size: 7px; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 3px; }
  .kpi-val { font-size: 15px; font-weight: 800; font-family: monospace; line-height: 1; }
  .kpi-sub { color: #6B7E99; font-size: 7px; margin-top: 3px; }
  .kpi-badge { display: inline-block; margin-top: 4px; padding: 1px 6px; border-radius: 3px; font-size: 7px; font-weight: 700; }

  /* charts row */
  .charts-row { display: flex; gap: 10px; flex: 1; overflow: hidden; }
  .card { background: #111827; border: 1px solid #1E2D45; border-radius: 10px; padding: 12px; overflow: hidden; }
  .card-title { color: #E2EAF4; font-size: 10px; font-weight: 700; margin-bottom: 2px; }
  .card-sub { color: #6B7E99; font-size: 8px; margin-bottom: 10px; }

  .funnel-card { width: 200px; flex-shrink: 0; }
  .chart-card { flex: 1; }

  /* funnel bars */
  .funnel-item { display: flex; align-items: center; gap: 6px; margin-bottom: 6px; }
  .funnel-dot { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }
  .funnel-bar-wrap { flex: 1; height: 14px; background: #1E2D45; border-radius: 3px; overflow: hidden; }
  .funnel-bar { height: 100%; border-radius: 3px; display: flex; align-items: center; padding-left: 5px; }
  .funnel-bar-label { color: #fff; font-size: 7px; font-weight: 700; font-family: monospace; white-space: nowrap; }
  .funnel-num { color: #E2EAF4; font-size: 8px; font-family: monospace; font-weight: 600; min-width: 38px; text-align: right; }

  /* line chart mockup */
  .chart-area { position: relative; height: 160px; }
  .y-axis { position: absolute; left: 0; top: 0; bottom: 20px; width: 30px; display: flex; flex-direction: column; justify-content: space-between; }
  .y-label { color: #6B7E99; font-size: 7px; font-family: monospace; text-align: right; }
  .chart-inner { position: absolute; left: 34px; right: 0; top: 0; bottom: 20px; }
  .x-axis { position: absolute; left: 34px; right: 0; bottom: 0; display: flex; justify-content: space-between; }
  .x-label { color: #6B7E99; font-size: 7px; font-family: monospace; }

  /* scenario bar */
  .scenario-card { flex-shrink: 0; }
  .scen-row { display: flex; gap: 10px; margin-top: 8px; }
  .scen-item { flex: 1; }
  .scen-label { font-size: 8px; font-weight: 700; margin-bottom: 3px; }
  .scen-val { font-size: 13px; font-weight: 800; font-family: monospace; color: #E2EAF4; }
  .scen-bar-wrap { height: 4px; background: #1E2D45; border-radius: 2px; margin-top: 5px; }
  .scen-bar { height: 100%; border-radius: 2px; }
  .scen-pct { color: #6B7E99; font-size: 7px; margin-top: 2px; }
</style>
</head>
<body>
<div style="padding: 16px; background: #0A0F1E; min-height: 100vh;">

  <!-- annotation top -->
  <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
    <div style="width: 8px; height: 8px; border-radius: 50%; background: #F0B429;"></div>
    <span style="color: #6B7E99; font-size: 10px; letter-spacing: 0.06em;">DASHBOARD PREVIEW — Japan Pharma BD Assessment Tool v4.0</span>
    <div style="flex:1; height: 1px; background: #1E2D45;"></div>
    <span style="color: #6B7E99; font-size: 9px;">李詩琳 Silynn Lee · 2025</span>
  </div>

  <div class="shell">

    <!-- HEADER -->
    <div class="hdr">
      <div class="hdr-icon">⬡</div>
      <div>
        <div class="hdr-title">Japan Oncology BD Assessment Tool</div>
        <div class="hdr-sub">ILLUSTRATIVE DATA · NHI + 新薬創出加算 + LOE Model · v4.0</div>
      </div>
      <div class="hdr-badges">
        <div class="badge badge-green">🛡 新薬創出加算 ON</div>
        <div class="badge badge-purple">🌸 孤児薬指定 ON</div>
        <div class="badge badge-orange">⚠️ LOE 第8年</div>
        <div class="badge badge-blue">🔬 ONCOLOGY · JAPAN MARKET</div>
      </div>
    </div>

    <div class="body">

      <!-- SIDEBAR -->
      <div class="sidebar">
        <div class="sidebar-section">📊 モデル入力パラメータ</div>

        <div class="section-label">患者漏斗モデル</div>

        <div class="slider-row">
          <div class="slider-label"><span class="slider-name">目標患病人口（日本）</span><span class="slider-val">8.5万人</span></div>
          <div class="slider-track"><div class="slider-fill" style="width:28%"></div><div class="slider-thumb" style="left:28%"></div></div>
        </div>
        <div class="slider-row">
          <div class="slider-label"><span class="slider-name">就診率 Diagnosis Rate</span><span class="slider-val">62%</span></div>
          <div class="slider-track"><div class="slider-fill" style="width:58%"></div><div class="slider-thumb" style="left:58%"></div></div>
        </div>
        <div class="slider-row">
          <div class="slider-label"><span class="slider-name">治療率 Treatment Rate</span><span class="slider-val">55%</span></div>
          <div class="slider-track"><div class="slider-fill" style="width:50%"></div><div class="slider-thumb" style="left:50%"></div></div>
        </div>
        <div class="slider-row">
          <div class="slider-label"><span class="slider-name">分子クラスシェア</span><span class="slider-val">30%</span></div>
          <div class="slider-track"><div class="slider-fill" style="width:33%"></div><div class="slider-thumb" style="left:33%"></div></div>
        </div>
        <div class="slider-row">
          <div class="slider-label"><span class="slider-name">自社ブランドシェア</span><span class="slider-val">22%</span></div>
          <div class="slider-track"><div class="slider-fill" style="width:35%"></div><div class="slider-thumb" style="left:35%"></div></div>
        </div>

        <div class="section-label">価格 & 市場環境</div>

        <div class="slider-row">
          <div class="slider-label"><span class="slider-name">年間治療費用</span><span class="slider-val">¥480万</span></div>
          <div class="slider-track"><div class="slider-fill" style="width:30%"></div><div class="slider-thumb" style="left:30%"></div></div>
        </div>
        <div class="slider-row">
          <div class="slider-label"><span class="slider-name">NHI薬価引き下げ</span><span class="slider-val">5%</span></div>
          <div class="slider-track"><div class="slider-fill" style="width:29%"></div><div class="slider-thumb" style="left:29%"></div></div>
        </div>
        <div class="slider-row">
          <div class="slider-label"><span class="slider-name">ランプアップ期間</span><span class="slider-val">3年</span></div>
          <div class="slider-track"><div class="slider-fill" style="width:40%"></div><div class="slider-thumb" style="left:40%"></div></div>
        </div>

        <div class="section-label" style="color:#34D399;">🏥 薬価特例制度</div>
        <div class="toggle toggle-green">
          <div class="toggle-row">
            <div class="pill pill-green"><div class="pill-dot"></div></div>
            <div><div class="toggle-label tg-green">新薬創出加算 適用</div><div class="toggle-sub">最初6年間 引き下げ免除</div></div>
          </div>
        </div>
        <div class="toggle toggle-purple">
          <div class="toggle-row">
            <div class="pill pill-purple"><div class="pill-dot"></div></div>
            <div><div class="toggle-label tg-purple">孤児薬指定</div><div class="toggle-sub">免除+4年 / 引き下げ幅 ÷2</div></div>
          </div>
        </div>

        <div class="section-label" style="color:#FB923C;">⚠️ 特許切れ・後発品参入</div>
        <div class="toggle toggle-orange">
          <div class="toggle-row">
            <div class="pill pill-orange"><div class="pill-dot"></div></div>
            <div><div class="toggle-label tg-orange">LOE シナリオ ON</div><div class="toggle-sub">後発品参入断崖シミュレーション</div></div>
          </div>
        </div>
        <div class="slider-row" style="margin-top:6px;">
          <div class="slider-label"><span class="slider-name">特許切れ年</span><span class="slider-val" style="color:#FB923C;">第8年</span></div>
          <div class="slider-track"><div class="slider-fill" style="width:43%; background: linear-gradient(90deg, #c2410c, #FB923C);"></div><div class="slider-thumb" style="left:43%; background:#FB923C;"></div></div>
        </div>
        <div class="slider-row">
          <div class="slider-label"><span class="slider-name">侵食率（最大）</span><span class="slider-val" style="color:#FB923C;">72%</span></div>
          <div class="slider-track"><div class="slider-fill" style="width:60%; background: linear-gradient(90deg, #c2410c, #FB923C);"></div><div class="slider-thumb" style="left:60%; background:#FB923C;"></div></div>
        </div>
      </div>

      <!-- MAIN -->
      <div class="main">

        <!-- KPI row -->
        <div class="kpi-row">
          <div class="kpi" style="border-color:#A78BFA55;">
            <div class="kpi-label">ピーク売上高</div>
            <div class="kpi-val" style="color:#A78BFA;">¥48.2億</div>
            <div class="kpi-sub">2031年</div>
          </div>
          <div class="kpi" style="border-color:#A78BFA55;">
            <div class="kpi-label">15年累計売上</div>
            <div class="kpi-val" style="color:#A78BFA;">¥412億</div>
            <div class="kpi-sub">LOE込み</div>
          </div>
          <div class="kpi">
            <div class="kpi-label">ブランド患者数</div>
            <div class="kpi-val" style="color:#E2EAF4;">3,087人</div>
            <div class="kpi-sub">定常時</div>
          </div>
          <div class="kpi" style="border-color:#FB923C55;">
            <div class="kpi-label">LOE 累計損失</div>
            <div class="kpi-val" style="color:#FB923C;">-¥189億</div>
            <div class="kpi-sub">特許切れ 第8年 / 侵食率 72%</div>
            <div class="kpi-badge" style="background:#FB923C22; color:#FB923C;">後発品競争影響</div>
          </div>
        </div>

        <!-- Charts row -->
        <div class="charts-row">

          <!-- Funnel -->
          <div class="card funnel-card">
            <div class="card-title">患者漏斗 Patient Funnel</div>
            <div class="card-sub">総患病人口 → 自社ブランド</div>

            <div class="funnel-item">
              <div class="funnel-dot" style="background:#4FC3F7;"></div>
              <div class="funnel-bar-wrap">
                <div class="funnel-bar" style="width:100%; background:#4FC3F7;">
                  <span class="funnel-bar-label">85,000</span>
                </div>
              </div>
            </div>
            <div style="color:#6B7E99; font-size:7px; text-align:right; margin:-4px 0 4px;">総患病人口 ↓62%</div>

            <div class="funnel-item">
              <div class="funnel-dot" style="background:#29B6F6;"></div>
              <div class="funnel-bar-wrap">
                <div class="funnel-bar" style="width:62%; background:#29B6F6;">
                  <span class="funnel-bar-label">52,700</span>
                </div>
              </div>
            </div>
            <div style="color:#6B7E99; font-size:7px; text-align:right; margin:-4px 0 4px;">診断済み ↓55%</div>

            <div class="funnel-item">
              <div class="funnel-dot" style="background:#039BE5;"></div>
              <div class="funnel-bar-wrap">
                <div class="funnel-bar" style="width:38%; background:#039BE5;">
                  <span class="funnel-bar-label">28,985</span>
                </div>
              </div>
            </div>
            <div style="color:#6B7E99; font-size:7px; text-align:right; margin:-4px 0 4px;">治療中 ↓30%</div>

            <div class="funnel-item">
              <div class="funnel-dot" style="background:#0277BD;"></div>
              <div class="funnel-bar-wrap">
                <div class="funnel-bar" style="width:12%; background:#0277BD;">
                  <span class="funnel-bar-label">8,696</span>
                </div>
              </div>
            </div>
            <div style="color:#6B7E99; font-size:7px; text-align:right; margin:-4px 0 4px;">クラス内 ↓22%</div>

            <div class="funnel-item">
              <div class="funnel-dot" style="background:#F0B429;"></div>
              <div class="funnel-bar-wrap">
                <div class="funnel-bar" style="width:4%; background:#F0B429; min-width:40px;">
                  <span class="funnel-bar-label">3,087</span>
                </div>
              </div>
            </div>
            <div style="color:#F0B429; font-size:7px; text-align:right; margin:-4px 0 4px; font-weight:700;">自社ブランド</div>
          </div>

          <!-- Line chart -->
          <div class="card chart-card">
            <div class="card-title">15年売上予測 Revenue Forecast</div>
            <div class="card-sub">孤児薬+新薬創出加算 ／ LOE 第8年（2033）/ NHI調整</div>

            <!-- SVG chart mockup -->
            <svg width="100%" height="175" viewBox="0 0 420 175">
              <!-- grid lines -->
              <line x1="32" y1="10" x2="32" y2="145" stroke="#1E2D45" stroke-width="0.5"/>
              <line x1="32" y1="145" x2="415" y2="145" stroke="#1E2D45" stroke-width="0.5"/>
              <line x1="32" y1="10" x2="415" y2="10" stroke="#1E2D45" stroke-width="0.5" stroke-dasharray="3,3"/>
              <line x1="32" y1="47" x2="415" y2="47" stroke="#1E2D45" stroke-width="0.5" stroke-dasharray="3,3"/>
              <line x1="32" y1="84" x2="415" y2="84" stroke="#1E2D45" stroke-width="0.5" stroke-dasharray="3,3"/>
              <line x1="32" y1="121" x2="415" y2="121" stroke="#1E2D45" stroke-width="0.5" stroke-dasharray="3,3"/>
              <!-- y labels -->
              <text x="28" y="14" fill="#6B7E99" font-size="7" text-anchor="end" font-family="monospace">60億</text>
              <text x="28" y="51" fill="#6B7E99" font-size="7" text-anchor="end" font-family="monospace">45億</text>
              <text x="28" y="88" fill="#6B7E99" font-size="7" text-anchor="end" font-family="monospace">30億</text>
              <text x="28" y="125" fill="#6B7E99" font-size="7" text-anchor="end" font-family="monospace">15億</text>
              <!-- x labels -->
              <text x="38"  y="158" fill="#6B7E99" font-size="7" text-anchor="middle" font-family="monospace">2026</text>
              <text x="90"  y="158" fill="#6B7E99" font-size="7" text-anchor="middle" font-family="monospace">2028</text>
              <text x="142" y="158" fill="#6B7E99" font-size="7" text-anchor="middle" font-family="monospace">2030</text>
              <text x="194" y="158" fill="#6B7E99" font-size="7" text-anchor="middle" font-family="monospace">2032</text>
              <text x="246" y="158" fill="#6B7E99" font-size="7" text-anchor="middle" font-family="monospace">2034</text>
              <text x="298" y="158" fill="#6B7E99" font-size="7" text-anchor="middle" font-family="monospace">2036</text>
              <text x="350" y="158" fill="#6B7E99" font-size="7" text-anchor="middle" font-family="monospace">2038</text>
              <text x="402" y="158" fill="#6B7E99" font-size="7" text-anchor="middle" font-family="monospace">2040</text>

              <!-- NHI cut markers (shield = protected) -->
              <line x1="90"  y1="10" x2="90"  y2="145" stroke="#34D399" stroke-width="0.8" stroke-dasharray="3,3" opacity="0.5"/>
              <text x="90"  y="8" fill="#34D399" font-size="7" text-anchor="middle">🛡</text>
              <line x1="142" y1="10" x2="142" y2="145" stroke="#34D399" stroke-width="0.8" stroke-dasharray="3,3" opacity="0.5"/>
              <text x="142" y="8" fill="#34D399" font-size="7" text-anchor="middle">🛡</text>
              <line x1="194" y1="10" x2="194" y2="145" stroke="#34D399" stroke-width="0.8" stroke-dasharray="3,3" opacity="0.5"/>
              <text x="194" y="8" fill="#34D399" font-size="7" text-anchor="middle">🛡</text>
              <line x1="246" y1="10" x2="246" y2="145" stroke="#FF6B6B" stroke-width="0.8" stroke-dasharray="3,3" opacity="0.5"/>
              <text x="246" y="8" fill="#FF6B6B" font-size="7" text-anchor="middle">薬↓</text>
              <line x1="298" y1="10" x2="298" y2="145" stroke="#FF6B6B" stroke-width="0.8" stroke-dasharray="3,3" opacity="0.5"/>
              <text x="298" y="8" fill="#FF6B6B" font-size="7" text-anchor="middle">薬↓</text>

              <!-- LOE cliff marker -->
              <line x1="220" y1="10" x2="220" y2="145" stroke="#FB923C" stroke-width="1.5" opacity="0.9"/>
              <text x="220" y="8" fill="#FB923C" font-size="8" text-anchor="middle" font-weight="bold">⚠LOE</text>

              <!-- Line: no NHI ceiling (dashed blue) -->
              <polyline points="38,145 64,120 90,96 116,76 142,63 168,57 194,53 220,50 246,48 272,46 298,44 324,43 350,42 376,41 402,41"
                fill="none" stroke="#4FC3F7" stroke-width="1.2" stroke-dasharray="5,3" opacity="0.6"/>
              <!-- Line: standard NHI (dashed red) -->
              <polyline points="38,145 64,120 90,96 116,79 142,68 168,62 194,58 220,55 246,80 272,90 298,100 324,108 350,114 376,118 402,121"
                fill="none" stroke="#FF6B6B" stroke-width="1.2" stroke-dasharray="4,4" opacity="0.6"/>
              <!-- Line: orphan + shinyaku + LOE (MAIN, purple) -->
              <polyline points="38,145 64,120 90,95 116,74 142,61 168,54 194,50 220,47 246,62 272,72 298,80 324,87 350,93 376,97 402,100"
                fill="none" stroke="#A78BFA" stroke-width="2.5"/>
              <!-- dots on main line -->
              <circle cx="38"  cy="145" r="2.5" fill="#A78BFA"/>
              <circle cx="90"  cy="95"  r="2.5" fill="#A78BFA"/>
              <circle cx="142" cy="61"  r="2.5" fill="#A78BFA"/>
              <circle cx="194" cy="50"  r="2.5" fill="#A78BFA"/>
              <circle cx="220" cy="47"  r="3.5" fill="#FB923C"/>
              <circle cx="246" cy="62"  r="2.5" fill="#A78BFA"/>
              <circle cx="298" cy="80"  r="2.5" fill="#A78BFA"/>
              <circle cx="402" cy="100" r="2.5" fill="#A78BFA"/>

              <!-- peak annotation -->
              <line x1="194" y1="50" x2="210" y2="30" stroke="#A78BFA" stroke-width="0.8" stroke-dasharray="2,2"/>
              <rect x="210" y="18" width="55" height="14" rx="3" fill="#111827" stroke="#A78BFA" stroke-width="0.5"/>
              <text x="237" y="28" fill="#A78BFA" font-size="7" text-anchor="middle" font-family="monospace">Peak ¥48.2億</text>

              <!-- LOE drop annotation -->
              <line x1="233" y1="55" x2="260" y2="38" stroke="#FB923C" stroke-width="0.8" stroke-dasharray="2,2"/>
              <rect x="260" y="26" width="54" height="14" rx="3" fill="#111827" stroke="#FB923C" stroke-width="0.5"/>
              <text x="287" y="36" fill="#FB923C" font-size="7" text-anchor="middle" font-family="monospace">-72% 侵食開始</text>

              <!-- legend -->
              <line x1="36" y1="168" x2="52" y2="168" stroke="#4FC3F7" stroke-width="1.2" stroke-dasharray="4,2"/>
              <text x="55" y="171" fill="#6B7E99" font-size="7" font-family="monospace">引き下げなし</text>
              <line x1="120" y1="168" x2="136" y2="168" stroke="#FF6B6B" stroke-width="1.2" stroke-dasharray="3,3"/>
              <text x="139" y="171" fill="#6B7E99" font-size="7" font-family="monospace">標準NHI</text>
              <line x1="194" y1="168" x2="210" y2="168" stroke="#A78BFA" stroke-width="2.5"/>
              <text x="213" y="171" fill="#A78BFA" font-size="7" font-family="monospace" font-weight="bold">孤児薬+加算+LOE</text>
            </svg>
          </div>
        </div>

        <!-- Scenario comparison -->
        <div class="card scenario-card" style="flex-shrink:0;">
          <div class="card-title">シナリオ比較 Scenario Comparison</div>
          <div class="card-sub">15年累計売上 — 薬価制度シナリオ別（LOE込み）</div>
          <div class="scen-row">
            <div class="scen-item">
              <div class="scen-label" style="color:#4FC3F7;">① 引き下げなし（上限）</div>
              <div class="scen-val">¥601億</div>
              <div class="scen-bar-wrap"><div class="scen-bar" style="width:100%; background:#4FC3F7;"></div></div>
              <div class="scen-pct">100% vs 上限</div>
            </div>
            <div class="scen-item">
              <div class="scen-label" style="color:#A78BFA;">② 孤児薬+新薬創出加算</div>
              <div class="scen-val">¥412億</div>
              <div class="scen-bar-wrap"><div class="scen-bar" style="width:69%; background:#A78BFA;"></div></div>
              <div class="scen-pct">69% vs 上限</div>
            </div>
            <div class="scen-item">
              <div class="scen-label" style="color:#34D399;">③ 新薬創出加算のみ</div>
              <div class="scen-val">¥374億</div>
              <div class="scen-bar-wrap"><div class="scen-bar" style="width:62%; background:#34D399;"></div></div>
              <div class="scen-pct">62% vs 上限</div>
            </div>
            <div class="scen-item">
              <div class="scen-label" style="color:#FF6B6B;">④ 標準NHI引き下げ</div>
              <div class="scen-val">¥298億</div>
              <div class="scen-bar-wrap"><div class="scen-bar" style="width:50%; background:#FF6B6B;"></div></div>
              <div class="scen-pct">50% vs 上限</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- annotation bottom -->
  <div style="display: flex; justify-content: space-between; margin-top: 8px;">
    <span style="color: #6B7E99; font-size: 9px;">Built with React + Recharts · Deployed on Vercel</span>
    <span style="color: #6B7E99; font-size: 9px;">Illustrative data only — not for actual investment decisions</span>
  </div>

</div>
</body>
</html>
